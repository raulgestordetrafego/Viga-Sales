              "type": "string"
            },
            {
              "id": "cfg-campaign",
              "name": "campaign_id",
              "value": "SUBSTITUA_PELO_ID_DA_CAMPANHA",
              "type": "string"
            },
            {
              "id": "cfg-apify",
              "name": "apify_token",
              "value": "SUBSTITUA_PELO_SEU_TOKEN_APIFY",
              "type": "string"
            },
            {
