# Evolution API Configuration
EVOLUTION_API_URL=https://sua-evolution-api.seudominio.com
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE=NomeDaInstancia

# Webhook Configuration
# WEBHOOK_URL: URL pública desta aplicação para receber eventos da Evolution API.
# Exemplo: https://viga-sales.seudominio.com/webhook/evolution
WEBHOOK_URL=

# WEBHOOK_SECRET: Segredo compartilhado com a Evolution API para validar a origem dos webhooks.
# Gere com: openssl rand -hex 32
# Configure o mesmo valor no painel da Evolution API como "webhook secret/apikey".
WEBHOOK_SECRET=

# FORWARD_WEBHOOK_URL: (Opcional) Se quiser encaminhar os eventos para o n8n ou outro serviço.
# Deixe vazio para desativar.
FORWARD_WEBHOOK_URL=

# Server Configuration
PORT=3000
NODE_ENV=development

# App URL (usado para gerar URLs de webhook)
APP_URL=https://viga-sales.seudominio.com

# Auth / Security
# Master admin credentials (criado automaticamente no primeiro start se não existir)
CRM_MASTER_EMAIL=seuemail@dominio.com
CRM_MASTER_PASSWORD=SenhaForteAqui!
# Chave Gemini (usado para geração de mensagens de prospecção com IA)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Prospecção Automática - Apify (Google Maps / Instagram Scraper)
# Crie uma conta em https://apify.com e gere um token em Settings > API & Integrations
APIFY_TOKEN=

# Database Configuration
# Default: SQLite em ./db/crm.sqlite (criado automaticamente, sem setup)
DB_PATH=./db/crm.sqlite
# Para PostgreSQL (ex: Supabase, Neon), forneça a connection string:
DATABASE_URL=
